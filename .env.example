# MailNeo Environment Configuration
# Copy this file to .env and fill in your values
# Run: node scripts/setup.js  (auto-generates .env with secure random keys)

# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── Security (REQUIRED) ──────────────────────────────
# Generate with: node scripts/setup.js
ENCRYPTION_KEY=your-64-char-hex-key-here
SESSION_SECRET=your-64-char-session-secret-here

# ─── OpenAI (Optional – enables AI features) ──────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Override model
# OPENAI_MODEL=gpt-5-mini

# ─── Registration ─────────────────────────────────────
# Set to 'false' to prevent new users from signing up
ALLOW_REGISTRATION=true

# ─── TLS Certificate Validation ───────────────────────
# By default TLS certificates are validated for IMAP and SMTP connections.
# Set to 'false' ONLY if your mail server uses a self-signed certificate.
# IMAP_TLS_REJECT_UNAUTHORIZED=false
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# ─── Node Environment ─────────────────────────────────
NODE_ENV=development
