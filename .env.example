# NeoMail Environment Configuration
# Copy this file to .env and fill in your values
# Run: node scripts/setup.js  (auto-generates .env with secure random keys)

# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── Security (REQUIRED) ──────────────────────────────
# Generate with: node scripts/setup.js
ENCRYPTION_KEY=your-64-char-hex-key-here
SESSION_SECRET=your-64-char-session-secret-here

# ─── OpenAI (Optional – enables AI features) ──────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Override model
# OPENAI_MODEL=gpt-5-mini

# ─── Registration ─────────────────────────────────────
# Set to 'false' to prevent new users from signing up
ALLOW_REGISTRATION=true

# ─── Node Environment ─────────────────────────────────
NODE_ENV=development

# ─── Backups (Optional) ───────────────────────────────
# Set to a local directory path to enable automatic database backups.
# A timestamped folder is created at startup and every 6 hours.
# The backup includes the SQLite database AND this .env file (which
# contains your ENCRYPTION_KEY – keep it safe).
# BACKUP_PATH=/var/backups/neomail
